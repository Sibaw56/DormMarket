@page "{id}"
@model GMCC.Pages.ContactOwnerStudent
@{
    ViewData["Title"] = "Message Owner";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DormMarket</title>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #f9fafb;
            margin: 0;
            color: #1f2937;
        }

        .navbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 32px;
        }

        .navbar-brand {
            font-size: 18px;
            font-weight: 800;
            color: #1f2937;
        }

        .navbar-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .navbar-links a {
            text-decoration: none;
            color: #6b7280;
            font-size: 14px;
        }

        .navbar-links a.active {
            color: #1f2937;
            font-weight: 700;
        }

        .avatar-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #d1d5db;
        }

        .container {
            max-width: 640px;
            margin: 0 auto;
            padding: 28px 32px 60px;
        }

        .page-title {
            font-size: 18px;
            font-weight: 800;
            margin: 0 0 8px;
        }

        .page-subtitle {
            font-size: 13px;
            color: #6b7280;
            line-height: 1.5;
            margin-bottom: 24px;
        }

        .contact-card {
            display: flex;
            align-items: center;
            gap: 14px;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            background: #fff;
            padding: 16px;
            margin-bottom: 16px;
        }

        .contact-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #d1d5db;
            flex-shrink: 0;
        }

        .contact-body {
            flex: 1;
            min-width: 0;
        }

        .contact-label {
            font-size: 13px;
            font-weight: 700;
            color: #1f2937;
            margin-bottom: 8px;
        }

        .contact-value {
            padding: 8px 12px;
            border-radius: 6px;
            background: #f3f4f6;
            font-size: 13px;
            color: #374151;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .btn-contact {
            flex-shrink: 0;
            background: #0f766e;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 18px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <span class="navbar-brand">DormMarket</span>
        <div class="navbar-links">
            <a asp-page="/BrowseDormStudent" class="active">Browse</a>
            <a asp-page="/ProfileStudent">Profile</a>
        </div>
        <div class="avatar-circle"></div>
    </nav>

    <div class="container">
        <h1 class="page-title">Contact the Owner</h1>
        <p class="page-subtitle">@Model.Dorm.Name : reach out directly to ask about vacancy or arrange a viewing</p>

        <div class="contact-card">
            <div class="contact-avatar"></div>
            <div class="contact-body">
                <div class="contact-label">Messenger</div>
                <div class="contact-value">@Model.Dorm.MessengerLink</div>
            </div>
            <a href="@Model.Dorm.MessengerLink" target="_blank" rel="noopener" class="btn-contact">Open</a>
        </div>

        <div class="contact-card">
            <div class="contact-avatar"></div>
            <div class="contact-body">
                <div class="contact-label">Contact Number</div>
                <div class="contact-value">@Model.Dorm.OwnerContactNumber</div>
            </div>
            <a href="tel:@Model.Dorm.OwnerContactNumber" class="btn-contact">Call</a>
        </div>

        <div class="contact-card">
            <div class="contact-avatar"></div>
            <div class="contact-body">
                <div class="contact-label">Other (Viber/WhatsApp)</div>
                <div class="contact-value">@Model.Dorm.OtherContactLink</div>
            </div>
            <a href="@Model.Dorm.OtherContactLink" target="_blank" rel="noopener" class="btn-contact">Open</a>
        </div>
    </div>
</body>
</html>
