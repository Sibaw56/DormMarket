@page
@model GMCC.Pages.MapStudent
@{
    ViewData["Title"] = Model.ListingNotFound ? "Dorm not found" : $"{Model.DormitoryName} - Map";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DormMarket</title>
    <style>
        * { box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #f9fafb;
            margin: 0;
            color: #1f2937;
        }

        .navbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 32px;
        }

        .navbar-brand {
            font-size: 18px;
            font-weight: 800;
        }

        .navbar-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .navbar-links a {
            text-decoration: none;
            color: #6b7280;
            font-size: 14px;
        }

        .navbar-links a.active {
            color: #1f2937;
            font-weight: 700;
        }

        .avatar-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #d1d5db;
        }

        .container {
            max-width: 780px;
            margin: 0 auto;
            padding: 24px 32px 60px;
        }

        .dorm-name {
            font-size: 17px;
            font-weight: 800;
            margin-bottom: 2px;
        }

        .dorm-location {
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 18px;
        }

        .map-frame {
            width: 100%;
            height: 380px;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            overflow: hidden;
        }

        .map-frame iframe {
            width: 100%;
            height: 100%;
            border: 0;
        }

        .map-caption {
            font-size: 12px;
            color: #9ca3af;
            margin-top: 12px;
        }

        .btn-open-maps {
            display: inline-block;
            margin-top: 16px;
            background: #1f2937;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 18px;
            font-size: 13px;
            font-weight: 700;
            text-decoration: none;
            cursor: pointer;
        }

        .not-found {
            text-align: center;
            padding: 80px 20px;
        }

        .not-found a {
            color: #0f766e;
            font-weight: 700;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <span class="navbar-brand">DormMarket</span>
        <div class="navbar-links">
            <a asp-page="/BrowseDormStudent">Browse</a>
            <a asp-page="/ProfileStudent">Profile</a>
        </div>
        <div class="avatar-circle"></div>
    </nav>

    <div class="container">
        @if (Model.ListingNotFound)
        {
            <div class="not-found">
                <p>This dorm listing couldn't be found.</p>
                <a asp-page="/BrowseDormStudent">Back to Browse</a>
            </div>
        }
        else
        {
            <div class="dorm-name">@Model.DormitoryName</div>
            <div class="dorm-location">
                @Model.Location
                @if (!string.IsNullOrEmpty(Model.NearestSchool))
                {
                    <text> &middot; Near @Model.NearestSchool</text>
                }
            </div>

            <div class="map-frame">
                <iframe src="@Model.EmbedMapUrl" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
            </div>

            <p class="map-caption">Map centered on the dormitory's listed address. Pan and zoom to explore nearby streets and landmarks.</p>

            <a href="@Model.OpenInGoogleMapsUrl" target="_blank" rel="noopener noreferrer" class="btn-open-maps">Open in Google Maps</a>
        }
    </div>
</body>
</html>