@page
@model GMCC.Pages.BrowseDormOwner
@{
    ViewData["Title"] = "Owner Dashboard";
}

<style>
    body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f9fafb;
        margin: 0;
    }

    .navbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 32px;
        background: #fff;
        border-bottom: 1px solid #e5e7eb;
    }

    .navbar-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .brand {
        font-weight: 800;
        font-size: 18px;
        color: #1f2937;
    }

    .badge-owner {
        font-size: 11px;
        font-weight: 700;
        color: #6b7280;
        border: 1px solid #d1d5db;
        border-radius: 12px;
        padding: 2px 10px;
    }

    .navbar-links {
        display: flex;
        gap: 24px;
        font-size: 14px;
        font-weight: 600;
    }

    .navbar-links a {
        color: #6b7280;
        text-decoration: none;
    }

    .navbar-links a.active {
        color: #1f2937;
    }

    .avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #d1d5db;
    }

    .content {
        max-width: 960px;
        margin: 0 auto;
        padding: 32px 24px;
    }

    .stat-card {
        display: inline-block;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 16px 24px;
        background: #fff;
        margin-bottom: 32px;
    }

    .stat-number {
        font-size: 24px;
        font-weight: 800;
        color: #1f2937;
    }

    .stat-label {
        font-size: 11px;
        font-weight: 700;
        color: #6b7280;
        letter-spacing: 0.03em;
    }

    .listings-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .listings-title {
        font-size: 13px;
        font-weight: 700;
        color: #374151;
        letter-spacing: 0.03em;
    }

    .btn-add {
        background: #374151;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 16px;
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
    }

    .listings-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .listing-card {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        overflow: hidden;
        background: #fff;
    }

    .listing-image {
        height: 120px;
        background: #e5e7eb;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        position: relative;
    }

    .listing-image::before {
        content: "×";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 32px;
        color: #9ca3af;
    }

    .listing-image-label {
        background: #fff;
        font-size: 10px;
        font-weight: 600;
        color: #374151;
        padding: 2px 6px;
        margin: 6px;
        border-radius: 3px;
        z-index: 1;
    }

    .listing-body {
        padding: 12px 14px;
    }

    .listing-bar {
        height: 6px;
        background: #d1d5db;
        border-radius: 3px;
        margin-bottom: 12px;
        width: 60%;
    }

    .listing-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .status-badge {
        font-size: 11px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 12px;
    }

    .status-vacant {
        background: #d1fae5;
        color: #059669;
    }

