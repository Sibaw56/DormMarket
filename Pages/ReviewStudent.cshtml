@page
@model GMCC.Pages.ReviewStudent
@{
    ViewData["Title"] = Model.ListingNotFound ? "Dorm not found" : $"Review {Model.DormitoryName}";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DormMarket</title>
    <style>
        * { box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #f0f4f3;
            margin: 0;
            color: #1f2937;
        }

        .navbar {
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 32px;
        }

        .navbar-brand {
            font-size: 18px;
            font-weight: 800;
        }

        .container {
            max-width: 620px;
            margin: 0 auto;
            padding: 28px 32px 60px;
        }

        .review-title {
            font-size: 20px;
            font-weight: 800;
            margin-bottom: 6px;
        }

        .review-subtitle {
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 24px;
            line-height: 1.5;
        }

        .section-label {
            display: block;
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.03em;
            color: #374151;
            margin-bottom: 10px;
        }

        .star-row {
            display: flex;
            gap: 6px;
            margin-bottom: 24px;
        }

        .star {
            font-size: 30px;
            color: #d1d5db;
            cursor: pointer;
            user-select: none;
            transition: color 0.1s;
        }

        .star.filled {
            color: #facc15;
        }

        .review-textarea {
            width: 100%;
            min-height: 90px;
            padding: 12px 14px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            font-size: 14px;
            font-family: inherit;
            box-sizing: border-box;
            resize: vertical;
            margin-bottom: 24px;
        }

        .upload-box {
            display: block;
            border: 1.5px dashed #cbd5e1;
            border-radius: 8px;
            background: #f9fafb;
            padding: 22px 10px;
            text-align: center;
            font-size: 13px;
            color: #9ca3af;
            cursor: pointer;
            position: relative;
            margin-bottom: 24px;
        }

        .upload-box input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
        }

        .upload-box.has-file {
            border-color: #10b981;
            background: #ecfdf5;
            color: #065f46;
        }

        .btn-post {
            background: #0f766e;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 12px 24px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
        }

        .error-message {
            background: #fee2e2;
            color: #b91c1c;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 20px;
        }

        .not-found {
            text-align: center;
            padding: 80px 20px;
        }

        .not-found a {
            color: #0f766e;
            font-weight: 700;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <span class="navbar-brand">DormMarket</span>
    </nav>

    <div class="container">
        @if (Model.ListingNotFound)
        {
            <div class="not-found">
                <p>This dorm listing couldn't be found.</p>
                <a asp-page="/BrowseDormStudent">Back to Browse</a>
            </div>
        }
        else
        {
            <div class="review-title">Review @Model.DormitoryName</div>
            <div class="review-subtitle">Show your experience to help other students. Verified renter's review are marked with a badge.</div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="error-message">@Model.ErrorMessage</div>
            }

            <form method="post" enctype="multipart/form-data" asp-page-handler="Submit" id="reviewForm">
                <input type="hidden" asp-for="DormId" />
                <input type="hidden" name="Rating" id="ratingInput" value="@Model.Rating" />

                <div class="section-label">YOUR RATING</div>
                <div class="star-row" id="starRow">
                    <span class="star" data-value="1">★</span>
                    <span class="star" data-value="2">★</span>
                    <span class="star" data-value="3">★</span>
                    <span class="star" data-value="4">★</span>
                    <span class="star" data-value="5">★</span>
                </div>

                <div class="section-label">YOUR REVIEW</div>
                <textarea name="ReviewText" class="review-textarea" placeholder="Write about your stay: room condition, owner responsiveness, safety, curfew, etc.">@Model.ReviewText</textarea>

                <div class="section-label">ADD A PHOTO (OPTIONAL)</div>
                <label class="upload-box" id="photoBox">
                    <span id="photoBoxText">↑ Upload a photo of your room or the dorm</span>
                    <input type="file" name="Photo" accept="image/*" onchange="previewFile(this, 'photoBox', 'photoBoxText')" />
                </label>

                <div class="section-label">ATTACH PROOF OF STAY (OPTIONAL)</div>
                <label class="upload-box" id="proofBox">
                    <span id="proofBoxText">↑ Upload contract, receipt or dorm ID</span>
                    <input type="file" name="ProofFile" accept="image/*,.pdf" onchange="previewFile(this, 'proofBox', 'proofBoxText')" />
                </label>

                <button type="submit" class="btn-post">Post Review</button>
            </form>
        }
    </div>

    <script>
        const stars = document.querySelectorAll('#starRow .star');
        const ratingInput = document.getElementById('ratingInput');

        function paintStars(value) {
            stars.forEach(s => {
                s.classList.toggle('filled', parseInt(s.dataset.value) <= value);
            });
        }

        stars.forEach(star => {
            star.addEventListener('click', () => {
                const value = parseInt(star.dataset.value);
                ratingInput.value = value;
                paintStars(value);
            });
        });

        paintStars(parseInt(ratingInput.value) || 0);

        function previewFile(input, boxId, textId) {
            const box = document.getElementById(boxId);
            const text = document.getElementById(textId);
            if (input.files && input.files.length > 0) {
                box.classList.add('has-file');
                text.textContent = '✓ ' + input.files[0].name;
            } else {
                box.classList.remove('has-file');
            }
        }
    </script>
</body>
</html>