@page
@model GMCC.Pages.Message
@{
    ViewData["Title"] = "Contact the Owner";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DormMarket</title>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #f9fafb;
            margin: 0;
            color: #1f2937;
        }

        .navbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 32px;
        }

        .navbar-brand {
            font-size: 18px;
            font-weight: 800;
            color: #1f2937;
        }

        .navbar-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .navbar-links a {
            text-decoration: none;
            color: #6b7280;
            font-size: 14px;
        }

        .navbar-links a.active {
            color: #1f2937;
            font-weight: 700;
        }

        .avatar-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #d1d5db;
            background-size: cover;
            background-position: center;
        }

        .layout {
            max-width: 640px;
            margin: 0 auto;
            padding: 32px 24px 60px;
        }

        .page-title {
            font-size: 22px;
            font-weight: 800;
            margin: 0 0 6px;
        }

        .page-subtitle {
            font-size: 14px;
            color: #6b7280;
            margin: 0 0 24px;
        }

        .page-subtitle strong {
            color: #1f2937;
        }

        .contact-card {
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            background: #fff;
            padding: 16px 18px;
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 16px;
        }

        .contact-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #d1d5db;
            background-size: cover;
            background-position: center;
            flex-shrink: 0;
        }

        .contact-body {
            flex: 1;
            min-width: 0;
        }

        .contact-label {
            font-size: 13px;
            font-weight: 700;
            color: #374151;
            margin: 0 0 6px;
        }

        .contact-value {
            font-size: 13px;
            color: #6b7280;
            background: #f3f4f6;
            border-radius: 6px;
            padding: 8px 10px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .contact-value.empty {
            font-style: italic;
            color: #9ca3af;
        }

        .btn-action {
            flex-shrink: 0;
            background: #0f766e;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 18px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            white-space: nowrap;
        }

        .btn-action.disabled {
            background: #d1d5db;
            color: #6b7280;
            pointer-events: none;
        }

        .not-found {
            text-align: center;
            padding: 80px 20px;
        }

        .not-found a {
            color: #0f766e;
            font-weight: 700;
        }

        .docs-toggle {
            width: 100%;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            padding: 14px 18px;
            font-size: 13px;
            font-weight: 700;
            color: #0f766e;
            cursor: pointer;
            text-align: left;
            margin-top: 8px;
        }

        .docs-toggle:hover {
            background: #f0fdfa;
        }

        .docs-panel {
            display: none;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            background: #fff;
            padding: 16px 18px;
            margin-top: 12px;
        }

        .docs-panel.open {
            display: block;
        }

        .docs-panel-title {
            font-size: 13px;
            font-weight: 700;
            color: #374151;
            margin: 0 0 12px;
        }

        .doc-link-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #f3f4f6;
        }

        .doc-link-row:last-of-type {
            border-bottom: none;
        }

        .doc-link-name {
            font-size: 13px;
            color: #374151;
        }

        .doc-link-view {
            font-size: 12px;
            font-weight: 700;
            color: #0f766e;
            text-decoration: none;
            background: #f0fdfa;
            padding: 6px 12px;
            border-radius: 6px;
        }

        .owner-notes {
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid #f3f4f6;
        }

        .owner-notes-label {
            font-size: 12px;
            font-weight: 700;
            color: #374151;
            margin: 0 0 6px;
        }

        .owner-notes-text {
            font-size: 13px;
            color: #6b7280;
            background: #f9fafb;
            border-radius: 6px;
            padding: 10px 12px;
            white-space: pre-wrap;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <span class="navbar-brand">DormMarket</span>
        <div class="navbar-links">
            <a asp-page="/BrowseDormStudent" class="active">Browse</a>
            <a asp-page="/ProfileStudent">Profile</a>
        </div>
        <div class="avatar-circle"></div>
    </nav>

    @if (Model.OwnerNotFound)
    {
        <div class="not-found">
            <p>We couldn't find this owner's contact details.</p>
            <a asp-page="/BrowseDormStudent">Back to Browse</a>
        </div>
    }
    else
    {
        <div class="layout">
            <p class="page-title">Contact the Owner</p>
            <p class="page-subtitle">
                @if (!string.IsNullOrWhiteSpace(Model.DormitoryName))
                {
                    <strong>@Model.DormitoryName</strong>
                    <text>: </text>
                }
                reach out directly to ask about vacancy or arrange a viewing
            </p>

            <div class="contact-card">
                <div class="contact-avatar" style="@(string.IsNullOrEmpty(Model.OwnerProfilePhotoPath) ? "" : $"background-image:url('{Model.OwnerProfilePhotoPath}');")"></div>
                <div class="contact-body">
                    <p class="contact-label">Messenger</p>
                    @if (!string.IsNullOrWhiteSpace(Model.MessengerLink))
                    {
                        <div class="contact-value">@Model.MessengerLink</div>
                    }
                    else
                    {
                        <div class="contact-value empty">Not provided</div>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.MessengerLink))
                {
                    <a href="@Model.MessengerLink" target="_blank" rel="noopener" class="btn-action">Open</a>
                }
                else
                {
                    <span class="btn-action disabled">Open</span>
                }
            </div>

            <div class="contact-card">
                <div class="contact-avatar" style="@(string.IsNullOrEmpty(Model.OwnerProfilePhotoPath) ? "" : $"background-image:url('{Model.OwnerProfilePhotoPath}');")"></div>
                <div class="contact-body">
                    <p class="contact-label">Contact Number</p>
                    @if (!string.IsNullOrWhiteSpace(Model.ContactNumber))
                    {
                        <div class="contact-value">@Model.ContactNumber</div>
                    }
                    else
                    {
                        <div class="contact-value empty">Not provided</div>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.ContactNumber))
                {
                    <a href="tel:@Model.ContactNumber" class="btn-action">Call</a>
                }
                else
                {
                    <span class="btn-action disabled">Call</span>
                }
            </div>

            <div class="contact-card">
                <div class="contact-avatar" style="@(string.IsNullOrEmpty(Model.OwnerProfilePhotoPath) ? "" : $"background-image:url('{Model.OwnerProfilePhotoPath}');")"></div>
                <div class="contact-body">
                    <p class="contact-label">Other (Viber/WhatsApp)</p>
                    @if (!string.IsNullOrWhiteSpace(Model.OtherContactLink))
                    {
                        <div class="contact-value">@Model.OtherContactLink</div>
                    }
                    else
                    {
                        <div class="contact-value empty">Not provided</div>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.OtherContactLink))
                {
                    <a href="@Model.OtherContactLink" target="_blank" rel="noopener" class="btn-action">Open</a>
                }
                else
                {
                    <span class="btn-action disabled">Open</span>
                }
            </div>

            @if (Model.HasAnyDocuments)
            {
                <button type="button" class="docs-toggle" onclick="document.getElementById('docsPanel').classList.toggle('open')">
                    View Business Documents
                </button>

                <div class="docs-panel" id="docsPanel">
                    <p class="docs-panel-title">Verification documents submitted by this owner</p>

                    @if (!string.IsNullOrWhiteSpace(Model.BusinessPermitPath))
                    {
                        <div class="doc-link-row">
                            <span class="doc-link-name">Business Permit / Mayor's Permit</span>
                            <a href="@Model.BusinessPermitPath" target="_blank" rel="noopener" class="doc-link-view">View</a>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.PropertyOwnershipPath))
                    {
                        <div class="doc-link-row">
                            <span class="doc-link-name">Certificate of Property Ownership / Land Title</span>
                            <a href="@Model.PropertyOwnershipPath" target="_blank" rel="noopener" class="doc-link-view">View</a>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.LeaseAuthorizationPath))
                    {
                        <div class="doc-link-row">
                            <span class="doc-link-name">Lease / Management Authorization</span>
                            <a href="@Model.LeaseAuthorizationPath" target="_blank" rel="noopener" class="doc-link-view">View</a>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.OwnerNotes))
                    {
                        <div class="owner-notes">
                            <p class="owner-notes-label">Note from the owner</p>
                            <div class="owner-notes-text">@Model.OwnerNotes</div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</body>
</html>