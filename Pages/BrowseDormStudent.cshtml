@page
@model GMCC.Pages.BrowseDormStudent
@{
    ViewData["Title"] = "Browse Dorms";
    Layout = null;

    var nearSchools = new[]
    {
        "Cebu Institute of Technology-University (CIT-U)",
        "University of San Carlos (USC)",
        "University of Cebu (UC)",
        "University of San Jose-Recoletos (USJR)",
        "Southwestern University PHINMA (SWU)",
        "Cebu Normal University (CNU)",
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DormMarket</title>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #f9fafb;
            margin: 0;
            color: #1f2937;
        }

        .navbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 32px;
        }

        .navbar-brand {
            font-size: 18px;
            font-weight: 800;
            color: #1f2937;
        }

        .navbar-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .navbar-links a {
            text-decoration: none;
            color: #6b7280;
            font-size: 14px;
        }

        .navbar-links a.active {
            color: #1f2937;
            font-weight: 700;
        }

        .avatar-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #d1d5db;
        }

        .layout {
            display: flex;
            align-items: flex-start;
            max-width: 1080px;
            margin: 0 auto;
            padding: 24px 32px 60px;
            gap: 32px;
        }

        .sidebar {
            width: 240px;
            flex-shrink: 0;
        }

        .filter-title {
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.03em;
            color: #374151;
            margin: 20px 0 10px;
        }

        .filter-title:first-child {
            margin-top: 0;
        }

        .price-value {
            font-size: 13px;
            font-weight: 700;
            color: #0f766e;
            margin-bottom: 8px;
        }

        .price-slider {
            width: 100%;
            accent-color: #0f766e;
        }

        .price-range-labels {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            color: #9ca3af;
            margin-top: 4px;
        }

        .checkbox-item {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            font-size: 13px;
            color: #374151;
            margin-bottom: 8px;
        }

        .checkbox-item input {
            margin-top: 2px;
            accent-color: #0f766e;
        }

        .btn-apply {
            width: 100%;
            background: #99f6e4;
            color: #0f766e;
            border: none;
            border-radius: 8px;
            padding: 10px 0;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 20px;
        }

        .content {
            flex: 1;
            min-width: 0;
        }

        .search-input {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            font-size: 14px;
            background: #fff;
            margin-bottom: 20px;
        }

        .results-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .dorm-card {
            display: block;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            text-decoration: none;
            color: inherit;
        }

        .dorm-price {
            font-size: 12px;
            font-weight: 700;
            color: #0f766e;
            margin-top: 4px;
        }

        .dorm-thumb {
            height: 150px;
            background: #e5e7eb;
        }

        .dorm-info {
            padding: 10px 12px;
        }

        .dorm-name {
            font-size: 13px;
            font-weight: 700;
            color: #1f2937;
        }

        .dorm-location {
            font-size: 12px;
            color: #9ca3af;
            margin-top: 2px;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <span class="navbar-brand">DormMarket</span>
        <div class="navbar-links">
            <a asp-page="/BrowseDormStudent" class="active">Browse</a>
            <a asp-page="/ProfileStudent">Profile</a>
        </div>
        <div class="avatar-circle"></div>
    </nav>

    <form method="get">
        <div class="layout">
            <div class="sidebar">
                <p class="filter-title">PRICE RANGE</p>
                <div class="price-value" id="priceValue">Up to &#8369;@Model.MaxPrice.ToString("N0")</div>
                <input type="range" name="MaxPrice" min="500" max="10000" step="500" value="@Model.MaxPrice" class="price-slider"
                       oninput="document.getElementById('priceValue').textContent = 'Up to ₱' + Number(this.value).toLocaleString();" />
                <div class="price-range-labels">
                    <span>&#8369;500</span>
                    <span>&#8369;10,000</span>
                </div>

                <p class="filter-title">NEAR SCHOOL (CEBU CITY)</p>
                @foreach (var school in nearSchools)
                {
                    <label class="checkbox-item">
                        <input type="checkbox" name="NearSchools" value="@school" checked="@(Model.NearSchools.Contains(school) ? "checked" : null)" />
                        <span>@school</span>
                    </label>
                }

                <p class="filter-title">ROOM TYPE</p>
                <label class="checkbox-item">
                    <input type="checkbox" name="RoomTypes" value="Solo" checked="@(Model.RoomTypes.Contains("Solo") ? "checked" : null)" />
                    <span>Solo</span>
                </label>
                <label class="checkbox-item">
                    <input type="checkbox" name="RoomTypes" value="Shared" checked="@(Model.RoomTypes.Contains("Shared") ? "checked" : null)" />
                    <span>Shared (2-4 pax)</span>
                </label>
                <label class="checkbox-item">
                    <input type="checkbox" name="RoomTypes" value="Bedspace" checked="@(Model.RoomTypes.Contains("Bedspace") ? "checked" : null)" />
                    <span>Bedspace</span>
                </label>

                <p class="filter-title">Curfew</p>
                <label class="checkbox-item">
                    <input type="checkbox" name="Curfew" value="HasCurfew" checked="@(Model.Curfew.Contains("HasCurfew") ? "checked" : null)" />
                    <span>Has Curfew</span>
                </label>
                <label class="checkbox-item">
                    <input type="checkbox" name="Curfew" value="NoCurfew" checked="@(Model.Curfew.Contains("NoCurfew") ? "checked" : null)" />
                    <span>No Curfew</span>
                </label>

                <p class="filter-title">Comfort Room (CR)</p>
                <label class="checkbox-item">
                    <input type="checkbox" name="ComfortRoom" value="OwnCR" checked="@(Model.ComfortRoom.Contains("OwnCR") ? "checked" : null)" />
                    <span>Own CR</span>
                </label>
                <label class="checkbox-item">
                    <input type="checkbox" name="ComfortRoom" value="SharedCR" checked="@(Model.ComfortRoom.Contains("SharedCR") ? "checked" : null)" />
                    <span>Shared CR</span>
                </label>

                <p class="filter-title">WiFi</p>
                <label class="checkbox-item">
                    <input type="checkbox" name="Wifi" value="HasWifi" checked="@(Model.Wifi.Contains("HasWifi") ? "checked" : null)" />
                    <span>Has WiFi</span>
                </label>
                <label class="checkbox-item">
                    <input type="checkbox" name="Wifi" value="NoWifi" checked="@(Model.Wifi.Contains("NoWifi") ? "checked" : null)" />
                    <span>No WiFi</span>
                </label>

                <button type="submit" class="btn-apply">Apply Filters</button>
            </div>

            <div class="content">
                <input type="text" name="Search" value="@Model.Search" class="search-input" placeholder="Search dorms by name or location..." />

                <div class="results-grid">
                    @foreach (var dorm in Model.Results)
                    {
                        var startingPrice = dorm.Rooms.Count > 0 ? dorm.Rooms[0].Price.Replace("P ", "₱") : "";
                        <a asp-page="/DormDetailsStudent" asp-route-id="@dorm.Id" class="dorm-card">
                            @if (!string.IsNullOrEmpty(dorm.ThumbnailPath))
                            {
                                <div class="dorm-thumb" style="background-image:url('@dorm.ThumbnailPath');background-size:cover;background-position:center;"></div>
                            }
                            else
                            {
                                <div class="dorm-thumb"></div>
                            }
                            <div class="dorm-info">
                                <div class="dorm-name">@dorm.Name</div>
                                <div class="dorm-location">@dorm.Location</div>
                                @if (!string.IsNullOrEmpty(startingPrice))
                                {
                                    <div class="dorm-price">@startingPrice/mo</div>
                                }
                            </div>
                        </a>
                    }
                </div>

                @if (Model.Results.Count == 0)
                {
                    <p style="color:#9ca3af;font-size:14px;margin-top:20px;">No dormitories match your filters yet.</p>
                }
            </div>
        </div>
    </form>
</body>
</html>