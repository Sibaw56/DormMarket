@page
@model GMCC.Pages.VerifyOwner
@{
    ViewData["Title"] = "VerifyOwner";
    Layout = null;
}

<style>
    body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f0f4f3;
        margin: 0;
    }

    .verify-wrapper {
        display: flex;
        justify-content: center;
        padding: 40px 20px;
    }

    .verify-card {
        width: 100%;
        max-width: 620px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 32px;
    }

    .brand-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

    .brand-name {
        font-size: 20px;
        font-weight: 800;
        color: #1f2937;
    }

    .owner-badge {
        background: #d1fae5;
        color: #065f46;
        font-size: 12px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 999px;
    }

    .verify-title {
        font-size: 18px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 24px;
    }

    .doc-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .doc-group {
        display: flex;
        flex-direction: column;
    }

    .doc-label {
        font-size: 12px;
        font-weight: 700;
        color: #374151;
        margin-bottom: 8px;
        letter-spacing: 0.02em;
    }

    .doc-upload {
        border: 1.5px dashed #cbd5e1;
        border-radius: 8px;
        background: #f9fafb;
        padding: 18px 10px;
        text-align: center;
        font-size: 12px;
        color: #6b7280;
        cursor: pointer;
        position: relative;
    }

    .doc-upload input[type="file"] {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
    }

    .doc-upload.has-file {
        border-style: solid;
        border-color: #0f766e;
        background: #f0fdfa;
    }

    .doc-upload-prompt {
        pointer-events: none;
    }

    .doc-upload-preview {
        display: none;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        pointer-events: none;
    }

    .doc-upload.has-file .doc-upload-prompt {
        display: none;
    }

    .doc-upload.has-file .doc-upload-preview {
        display: flex;
    }

    .doc-upload-thumb {
        max-width: 100%;
        max-height: 70px;
        border-radius: 4px;
        object-fit: cover;
    }

    .doc-upload-filename {
        font-size: 11px;
        font-weight: 700;
        color: #0f766e;
        word-break: break-all;
        max-width: 100%;
    }

    .doc-upload-filename::before {
        content: "✓ ";
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-size: 13px;
        font-weight: 700;
        color: #374151;
        margin-bottom: 8px;
    }

    .form-textarea {
        width: 100%;
        min-height: 70px;
        padding: 10px 12px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: 13px;
        font-family: inherit;
        box-sizing: border-box;
        resize: vertical;
    }

    .btn-submit {
        width: 100%;
        padding: 12px 0;
        background: #0f766e;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
    }

    .error-message {
        color: #dc2626;
        font-size: 13px;
        margin-bottom: 16px;
    }

    .success-message {
        color: #16a34a;
        font-size: 13px;
        margin-bottom: 16px;
    }
</style>

<div class="verify-wrapper">
    <div class="verify-card">
        <div class="brand-row">
            <span class="brand-name">DormMarket</span>
            <span class="owner-badge">Owner</span>
        </div>

        <div class="verify-title">Verify Your Dormitory Business</div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error-message">@Model.ErrorMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="success-message">@Model.SuccessMessage</div>
        }

        <form method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="OwnerId" />

            <div class="doc-grid">
                <div class="doc-group">
                    <div class="doc-label">BUSINESS PERMIT / MAYOR'S PERMIT</div>
                    <label class="doc-upload" id="box-BusinessPermit">
                        <span class="doc-upload-prompt">↑ Upload document (PDF / JPG)</span>
                        <span class="doc-upload-preview">
                            <img class="doc-upload-thumb" />
                            <span class="doc-upload-filename"></span>
                        </span>
                        <input type="file" asp-for="BusinessPermit" accept="image/*,.pdf" onchange="previewDoc(this)" />
                    </label>
                </div>

                <div class="doc-group">
                    <div class="doc-label">GOVERNMENT-ISSUED ID</div>
                    <label class="doc-upload" id="box-GovernmentId">
                        <span class="doc-upload-prompt">↑ Upload valid ID (PDF / JPG)</span>
                        <span class="doc-upload-preview">
                            <img class="doc-upload-thumb" />
                            <span class="doc-upload-filename"></span>
                        </span>
                        <input type="file" asp-for="GovernmentId" accept="image/*,.pdf" onchange="previewDoc(this)" />
                    </label>
                </div>

                <div class="doc-group">
                    <div class="doc-label">CERTIFICATE OF PROPERTY OWNERSHIP / LAND TITLE</div>
                    <label class="doc-upload" id="box-PropertyOwnership">
                        <span class="doc-upload-prompt">↑ Upload document (PDF / JPG)</span>
                        <span class="doc-upload-preview">
                            <img class="doc-upload-thumb" />
                            <span class="doc-upload-filename"></span>
                        </span>
                        <input type="file" asp-for="PropertyOwnership" accept="image/*,.pdf" onchange="previewDoc(this)" />
                    </label>
                </div>

                <div class="doc-group">
                    <div class="doc-label">OR: LEASE / MANAGEMENT AUTHORIZATION</div>
                    <label class="doc-upload" id="box-LeaseAuthorization">
                        <span class="doc-upload-prompt">↑ Upload if you manage (not own) the property</span>
                        <span class="doc-upload-preview">
                            <img class="doc-upload-thumb" />
                            <span class="doc-upload-filename"></span>
                        </span>
                        <input type="file" asp-for="LeaseAuthorization" accept="image/*,.pdf" onchange="previewDoc(this)" />
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">ADDITIONAL NOTES FOR REVIEWER (OPTIONAL)</label>
                <textarea asp-for="Notes" class="form-textarea" placeholder="Any extra context for the verification team"></textarea>
            </div>

            <button type="submit" class="btn-submit">Submit Documents for Review</button>
        </form>
    </div>
</div>

<script>
    function previewDoc(input) {
        const box = input.closest('.doc-upload');
        const filenameEl = box.querySelector('.doc-upload-filename');
        const thumbEl = box.querySelector('.doc-upload-thumb');

        if (!input.files || !input.files[0]) {
            box.classList.remove('has-file');
            return;
        }

        const file = input.files[0];
        filenameEl.textContent = file.name;
        box.classList.add('has-file');

        if (file.type.startsWith('image/')) {
            thumbEl.style.display = '';
            const reader = new FileReader();
            reader.onload = e => { thumbEl.src = e.target.result; };
            reader.readAsDataURL(file);
        } else {
            // PDFs (or anything non-image) get no thumbnail, just the filename
            thumbEl.style.display = 'none';
            thumbEl.removeAttribute('src');
        }
    }
</script>