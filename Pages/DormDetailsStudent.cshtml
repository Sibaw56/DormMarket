@page
@model GMCC.Pages.DormDetailsStudent
@{
    ViewData["Title"] = Model.ListingNotFound ? "Dorm not found" : Model.DormitoryName;
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DormMarket</title>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #f9fafb;
            margin: 0;
            color: #1f2937;
        }

        .navbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 32px;
        }

        .navbar-brand {
            font-size: 18px;
            font-weight: 800;
            color: #1f2937;
        }

        .navbar-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .navbar-links a {
            text-decoration: none;
            color: #6b7280;
            font-size: 14px;
        }

        .navbar-links a.active {
            color: #1f2937;
            font-weight: 700;
        }

        .avatar-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #d1d5db;
        }

        .layout {
            max-width: 1080px;
            margin: 0 auto;
            padding: 24px 32px 60px;
        }

        .top-grid {
            display: grid;
            grid-template-columns: 1.6fr 1fr;
            gap: 24px;
            align-items: start;
        }

        .gallery-main {
            height: 260px;
            border-radius: 10px;
            background: #e5e7eb;
            background-size: cover;
            background-position: center;
        }

        .gallery-thumbs {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin-top: 10px;
        }

        .gallery-thumb {
            height: 64px;
            border-radius: 8px;
            background: #e5e7eb;
            background-size: cover;
            background-position: center;
        }

        .info-card {
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            background: #fff;
            padding: 18px;
        }

        .info-price {
            font-size: 22px;
            font-weight: 800;
            color: #1f2937;
        }

        .info-price span {
            font-size: 13px;
            font-weight: 500;
            color: #9ca3af;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
            color: #6b7280;
            margin-top: 14px;
        }

        .info-row strong {
            color: #1f2937;
            font-weight: 700;
        }

        .status-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 700;
        }

        .status-vacant {
            background: #99f6e4;
            color: #0f766e;
        }

        .status-occupied {
            background: #fecaca;
            color: #b91c1c;
        }

        .btn-message {
            width: 100%;
            background: #0f766e;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 12px 0;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 18px;
        }

        .dorm-name {
            font-size: 24px;
            font-weight: 800;
            margin: 24px 0 4px;
        }

        .dorm-location {
            font-size: 14px;
            color: #6b7280;
        }

        .section-title {
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.03em;
            text-transform: uppercase;
            color: #374151;
            margin: 28px 0 12px;
        }

        .badge-row {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .amenity-badge {
            background: #ecfdf5;
            color: #0f766e;
            border-radius: 8px;
            padding: 8px 14px;
            font-size: 13px;
            font-weight: 600;
        }

        .map-wrap {
            position: relative;
            height: 220px;
            border-radius: 10px;
            background: #e5e7eb;
            overflow: hidden;
        }

        .btn-view-map {
            position: absolute;
            top: 12px;
            right: 12px;
            background: #fff;
            color: #0f766e;
            border: 1px solid #99f6e4;
            border-radius: 8px;
            padding: 8px 14px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
        }

        .description-text {
            font-size: 14px;
            line-height: 1.6;
            color: #374151;
        }

        .reviews-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 28px;
        }

        .btn-write-review {
            background: #0f766e;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 16px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
        }

        .review-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 0;
            border-bottom: 1px solid #f3f4f6;
        }

        .review-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #d1d5db;
            flex-shrink: 0;
        }

        .review-name {
            font-size: 13px;
            font-weight: 700;
        }

        .verified-badge {
            display: inline-block;
            background: #99f6e4;
            color: #0f766e;
            font-size: 11px;
            font-weight: 700;
            border-radius: 999px;
            padding: 2px 8px;
            margin-left: 8px;
        }

        .no-reviews {
            font-size: 13px;
            color: #9ca3af;
            padding: 12px 0;
        }

        .not-found {
            text-align: center;
            padding: 80px 20px;
        }

        .not-found a {
            color: #0f766e;
            font-weight: 700;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <span class="navbar-brand">DormMarket</span>
        <div class="navbar-links">
            <a asp-page="/BrowseDormStudent" class="active">Browse</a>
            <a asp-page="/ProfileStudent">Profile</a>
        </div>
        <div class="avatar-circle"></div>
    </nav>

    @if (Model.ListingNotFound)
    {
        <div class="not-found">
            <p>This dorm listing couldn't be found.</p>
            <a asp-page="/BrowseDormStudent">Back to Browse</a>
        </div>
    }
    else
    {
        <div class="layout">
            <div class="top-grid">
                <div>
                    @if (!string.IsNullOrEmpty(Model.MainPhotoPath))
                    {
                        <div class="gallery-main" style="background-image:url('@Model.MainPhotoPath');"></div>
                    }
                    else
                    {
                        <div class="gallery-main"></div>
                    }
                    @if (Model.GalleryPhotoPaths.Count > 0)
                    {
                        <div class="gallery-thumbs">
                            @foreach (var photo in Model.GalleryPhotoPaths.Take(4))
                            {
                                <div class="gallery-thumb" style="background-image:url('@photo');"></div>
                            }
                        </div>
                    }
                </div>

                <div class="info-card">
                    <div class="info-price">@Model.StartingPrice <span>/month</span></div>

                    @if (Model.Rooms.Count > 0)
                    {
                        <div class="info-row">
                            <span>Room Type</span>
                            <strong>@Model.Rooms[0].RoomTypeName</strong>
                        </div>
                        <div class="info-row">
                            <span>Availability</span>
                            <span class="status-badge @(Model.Rooms[0].Availability == "Available" || Model.Status == "Vacant" ? "status-vacant" : "status-occupied")">
                                @(Model.Status == "" ? Model.Rooms[0].Availability : Model.Status)
                            </span>
                        </div>
                    }

                    <a asp-page="/Message" asp-route-ownerId="@Model.OwnerId" asp-route-dormId="@Model.Id" class="btn-message" style="display:block;text-align:center;text-decoration:none;">
                        Message Owner
                    </a>
                </div>
            </div>

            <div class="dorm-name">@Model.DormitoryName</div>
            <div class="dorm-location">📍 @Model.Location</div>

            <p class="section-title">Amenities</p>
            <div class="badge-row">
                @foreach (var amenity in Model.Amenities)
                {
                    <span class="amenity-badge">✔ @amenity</span>
                }
                @if (!string.IsNullOrEmpty(Model.Curfew))
                {
                    <span class="amenity-badge">✔ Curfew: @Model.Curfew</span>
                }
            </div>

            <p class="section-title">Location</p>
            <div class="map-wrap">
                <a asp-page="/MapStudent" asp-route-dormId="@Model.Id" class="btn-view-map">View on Map</a>
            </div>

            <p class="section-title">Description</p>
            <p class="description-text">@Model.Description</p>

            <div class="reviews-header">
                <p class="section-title" style="margin:0;">Reviews</p>
                <a asp-page="/ReviewStudent" asp-route-dormId="@Model.Id" class="btn-write-review">Write a Review</a>
            </div>
            <p class="no-reviews">No reviews yet, be the first to share your experience.</p>
        </div>
    }
</body>
</html>