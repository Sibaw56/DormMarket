@page
@model GMCC.Pages.DashboardOwner
@{
    ViewData["Title"] = "Owner Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DormMarket</title>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #f9fafb;
            margin: 0;
            color: #1f2937;
        }

        .navbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 32px;
        }

        .navbar-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .navbar-brand {
            font-size: 18px;
            font-weight: 800;
            color: #1f2937;
        }

        .owner-badge {
            background: #d1fae5;
            color: #047857;
            font-size: 11px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 999px;
        }

        .navbar-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .navbar-links a {
            text-decoration: none;
            color: #6b7280;
            font-size: 14px;
        }

        .navbar-links a.active {
            color: #1f2937;
            font-weight: 700;
        }

        .navbar-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .avatar-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #d1d5db;
        }

        .container {
            max-width: 960px;
            margin: 0 auto;
            padding: 28px 32px 60px;
        }

        .stat-card {
            background: #ecfdf5;
            border: 1px solid #d1fae5;
            border-radius: 12px;
            padding: 24px 28px;
            max-width: 240px;
            margin-bottom: 28px;
        }

        .stat-number {
            font-size: 30px;
            font-weight: 800;
            color: #047857;
            line-height: 1;
        }

        .stat-label {
            font-size: 13px;
            color: #059669;
            margin-top: 8px;
        }

        .toolbar {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 20px;
        }

        .btn-add {
            background: #0f766e;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 18px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
        }

        .section-title {
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.04em;
            color: #374151;
            margin-bottom: 16px;
        }

        .listings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
        }

        .listing-card {
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
        }

        .listing-thumb {
            height: 130px;
            background: #e5e7eb;
        }

        .listing-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 14px;
            border-top: 1px solid #e5e7eb;
        }

        .status-pill {
            font-size: 12px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 999px;
        }

        .status-vacant {
            background: #d1fae5;
            color: #047857;
        }

        .status-occupied {
            background: #fee2e2;
            color: #b91c1c;
        }

        .status-draft {
            background: #e5e7eb;
            color: #4b5563;
        }

        .manage-link {
            background: none;
            border: none;
            color: #374151;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            padding: 0;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="navbar-left">
            <span class="navbar-brand">DormMarket</span>
            <span class="owner-badge">Owner</span>
        </div>
        <div class="navbar-links">
            <a asp-page="/DashboardOwner" class="active">Dashboard</a>
            <a asp-page="/ProfileOwner">Profile</a>
        </div>
        <div class="navbar-right">
            <div class="avatar-circle"></div>
        </div>
    </nav>

    <div class="container">
        @if (!string.IsNullOrEmpty(Model.ListingStatus))
        {
            <div style="background:#d1fae5;color:#047857;border:1px solid #a7f3d0;border-radius:8px;padding:12px 16px;font-size:13px;font-weight:600;margin-bottom:20px;">
                @Model.ListingStatus
            </div>
        }
        <div class="stat-card">
            <div class="stat-number">@Model.ActiveListingsCount</div>
            <div class="stat-label">Active Listings</div>
        </div>

        <div class="toolbar">
            <a asp-page="/AddDormOwner" style="text-decoration:none;">
                <button type="button" class="btn-add">+ Add Dormitory</button>
            </a>
        </div>

        <div class="section-title">MY LISTINGS</div>

        <div class="listings-grid">
            @foreach (var listing in Model.Listings)
            {
                var statusClass = listing.Status == "Vacant" ? "status-vacant"
                    : listing.Status == "Occupied" ? "status-occupied"
                    : "status-draft";

                <div class="listing-card">
                    @if (!string.IsNullOrEmpty(listing.ThumbnailPath))
                    {
                        <div class="listing-thumb" style="background-image:url('@listing.ThumbnailPath');background-size:cover;background-position:center;"></div>
                    }
                    else
                    {
                        <div class="listing-thumb"></div>
                    }
                    <div class="listing-footer">
                        <span class="status-pill @statusClass">@listing.Status</span>
                        <a asp-page="/BrowseDormOwner" asp-route-id="@listing.Id" class="manage-link">Manage</a>
                    </div>
                </div>
            }
        </div>

        @if (Model.Listings.Count == 0)
        {
            <p style="color:#9ca3af;font-size:14px;margin-top:20px;">You haven't added any dormitories yet.</p>
        }
    </div>
</body>
</html>