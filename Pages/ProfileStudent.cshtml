@page
@model GMCC.Pages.ProfileStudent
@{
    ViewData["Title"] = "Manage Profile";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DormMarket</title>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #f9fafb;
            margin: 0;
            color: #1f2937;
        }

        .navbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 32px;
        }

        .navbar-brand {
            font-size: 18px;
            font-weight: 800;
            color: #1f2937;
        }

        .navbar-links {
            display: flex;
            align-items: center;
            gap: 28px;
        }

        .navbar-links a {
            text-decoration: none;
            color: #6b7280;
            font-size: 14px;
        }

        .navbar-links a.active {
            color: #1f2937;
            font-weight: 700;
        }

        .avatar-circle {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #d1d5db;
        }

        .container {
            max-width: 760px;
            margin: 0 auto;
            padding: 28px 32px 60px;
        }

        .status-banner {
            background: #d1fae5;
            color: #047857;
            border: 1px solid #a7f3d0;
            border-radius: 8px;
            padding: 12px 16px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .profile-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .profile-identity {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .avatar-large {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: #d1d5db;
        }

        .profile-name {
            font-size: 16px;
            font-weight: 700;
        }

        .btn-change-photo {
            background: #0f766e;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 16px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
        }

        .badge-row {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 24px;
        }

        .verified-badge {
            background: #d1fae5;
            color: #047857;
            font-size: 12px;
            font-weight: 700;
            padding: 6px 12px;
            border-radius: 999px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 28px;
        }

        .form-label {
            display: block;
            font-size: 12px;
            font-weight: 700;
            color: #374151;
            margin-bottom: 6px;
            letter-spacing: 0.02em;
        }

        .form-input {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            font-size: 14px;
            font-family: inherit;
            background: #fff;
        }

        .section-title {
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.04em;
            color: #374151;
            margin: 0 0 14px;
        }

        .doc-list {
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 14px;
        }

        .doc-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 14px 16px;
            border-bottom: 1px solid #f3f4f6;
            background: #fff;
        }

        .doc-row:last-child {
            border-bottom: none;
        }

        .doc-title {
            font-size: 13px;
            font-weight: 700;
            color: #1f2937;
        }

        .doc-file {
            font-size: 12px;
            color: #9ca3af;
            margin-top: 2px;
        }

        .doc-pill {
            font-size: 12px;
            font-weight: 700;
            padding: 4px 10px;
            border-radius: 999px;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .doc-verified {
            background: #d1fae5;
            color: #047857;
        }

        .doc-missing {
            background: #f3f4f6;
            color: #6b7280;
        }

        .btn-upload {
            background: #0f766e;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 10px 16px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
        }

        .upload-form {
            margin-bottom: 24px;
        }

        .action-row {
            display: flex;
            align-items: center;
            gap: 16px; /* Space between Save Changes & Log Out */
            margin-top: 8px;
            margin-bottom: 36px; /* Space above Account Settings */
        }

        .btn-save {
            background: #0f766e;
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: 12px 22px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
        }

        .btn-logout {
            background: #99f6e4;
            color: #0f766e;
            border: none;
            border-radius: 8px;
            padding: 12px 22px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
        }

        .stacked-group {
            margin-bottom: 18px;
        }

        .change-password-link {
            width: 100%;
            text-align: left;
            background: #f3f4f6;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 12px;
            color: #6b7280;
            font-size: 13px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <span class="navbar-brand">DormMarket</span>
        <div class="navbar-links">
            <a asp-page="/BrowseDormStudent">Browse</a>
            <a asp-page="/ProfileStudent" class="active">Profile</a>
        </div>
        <div class="avatar-circle"></div>
    </nav>

    <div class="container">
        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="status-banner">@Model.StatusMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="status-banner" style="background:#fee2e2;color:#b91c1c;border-color:#fecaca;">@Model.ErrorMessage</div>
        }

        <form method="post" enctype="multipart/form-data" id="photoForm" asp-page-handler="ChangePhoto">
            <div class="profile-header">
                <div class="profile-identity">
                    @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
                    {
                        <div class="avatar-large" style="background-image:url('@Model.ProfilePhotoPath');background-size:cover;background-position:center;"></div>
                    }
                    else
                    {
                        <div class="avatar-large"></div>
                    }
                    <div class="profile-name">@Model.FullName</div>
                </div>
                <button type="button" class="btn-change-photo" onclick="document.getElementById('photoInput').click();">Change Photo</button>
                <input type="file" id="photoInput" name="ProfilePhoto" accept="image/*"
                       onchange="document.getElementById('photoForm').submit();" hidden />
            </div>
        </form>

        <form method="post" id="mainProfileForm">

            <div class="badge-row">
                @if (!string.IsNullOrEmpty(Model.VerifiedSchool))
                {
                    <span class="verified-badge">&check; Verified Student - @Model.VerifiedSchool</span>
                }
                @if (!string.IsNullOrEmpty(Model.VerifiedRentalDorm))
                {
                    <span class="verified-badge">&check; Verified Renter - @Model.VerifiedRentalDorm</span>
                }
            </div>

            <div class="form-grid">
                <div>
                    <label class="form-label">FULL NAME</label>
                    <input type="text" asp-for="FullName" class="form-input" />
                </div>
                <div>
                    <label class="form-label">EMAIL</label>
                    <input type="email" asp-for="Email" class="form-input" />
                </div>
                <div>
                    <label class="form-label">CONTACT NUMBER</label>
                    <input type="text" asp-for="ContactNumber" class="form-input" />
                </div>
                <div>
                    <label class="form-label">ADDRESS</label>
                    <input type="text" asp-for="Address" class="form-input" />
                </div>
            </div>

            <p class="section-title">STUDENT VERIFICATION</p>
            <div class="doc-list">
                @foreach (var doc in Model.StudentVerification)
                {
                    <div class="doc-row">
                        <div>
                            <div class="doc-title">@doc.Title</div>
                            <div class="doc-file">@doc.FileName</div>
                        </div>
                        @if (doc.Verified)
                        {
                            <span class="doc-pill doc-verified">&check; Verified</span>
                        }
                        else
                        {
                            <span class="doc-pill doc-missing">Not added</span>
                        }
                    </div>
                }
            </div>

            <p class="section-title">RENTAL VERIFICATION</p>
            <div class="doc-list">
                @foreach (var doc in Model.RentalVerification)
                {
                    <div class="doc-row">
                        <div>
                            <div class="doc-title">@doc.Title</div>
                            <div class="doc-file">@doc.FileName</div>
                        </div>
                        @if (doc.Verified)
                        {
                            <span class="doc-pill doc-verified">&check; Verified</span>
                        }
                        else
                        {
                            <span class="doc-pill doc-missing">Not added</span>
                        }
                    </div>
                }
            </div>
        </form>

        <!-- Upload Form -->
        <form method="post" enctype="multipart/form-data" id="proofForm" asp-page-handler="UploadProof" class="upload-form">
            <button type="button" class="btn-upload" onclick="document.getElementById('proofInput').click();">+ Upload New Proof of Stay</button>
            <input type="file" id="proofInput" name="ProofOfStayFile" accept="image/*"
                   onchange="document.getElementById('proofForm').submit();" hidden />
        </form>

        <!-- Action Row (Save & Logout below Upload button) -->
        <div class="action-row">
            <button type="submit" form="mainProfileForm" asp-page-handler="SaveChanges" class="btn-save">Save Changes</button>
            <button type="submit" form="mainProfileForm" asp-page-handler="Logout" class="btn-logout">Log Out</button>
        </div>

        <!-- Account Settings Form -->
        <form method="post" asp-page-handler="ChangePassword">
            <p class="section-title" style="margin-top:0;">ACCOUNT SETTINGS</p>
            <div class="stacked-group">
                <label class="form-label">CHANGE PASSWORD</label>
                <div class="form-grid" style="margin-bottom:10px;">
                    <div>
                        <label class="form-label">CURRENT PASSWORD</label>
                        <input type="password" name="CurrentPassword" class="form-input" />
                    </div>
                    <div></div>
                    <div>
                        <label class="form-label">NEW PASSWORD</label>
                        <input type="password" name="NewPassword" class="form-input" />
                    </div>
                    <div>
                        <label class="form-label">CONFIRM NEW PASSWORD</label>
                        <input type="password" name="ConfirmNewPassword" class="form-input" />
                    </div>
                </div>
                <button type="submit" class="change-password-link">Update Password</button>
            </div>
        </form>
    </div>
</body>
</html>