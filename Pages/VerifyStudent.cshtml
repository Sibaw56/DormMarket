@page
@model GMCC.Pages.VerifyStudent
@{
    ViewData["Title"] = "VerifyStudent";
    Layout = null;
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
        background: #ffffff;
        margin: 0;
        padding: 0;
    }

    .container {
        max-width: 480px;
        margin: 0 auto;
        padding: 32px 20px;
    }

    /* Header */
    .header-title {
        font-size: 20px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 20px;
    }

    /* Step indicator (two-tab bar) */
    .step-indicator {
        display: flex;
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 24px;
    }

    .step-badge {
        flex: 1;
        text-align: center;
        padding: 10px 12px;
        font-size: 13px;
        font-weight: 700;
        color: #fff;
    }

    .step-badge.active {
        background: #0f4c4c;
    }

    .step-badge.inactive {
        background: #7fb8b3;
    }

    /* Main title */
    .main-title {
        font-size: 22px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 10px;
    }

    .main-subtitle {
        font-size: 14px;
        color: #6b7280;
        line-height: 1.6;
        margin-bottom: 24px;
    }

    /* Form */
    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-size: 12px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 8px;
        letter-spacing: 0.02em;
    }

    /* File upload */
    .file-upload {
        border: 2px dashed #d1d5db;
        border-radius: 6px;
        padding: 28px 20px;
        text-align: center;
        cursor: pointer;
        transition: border-color 0.2s, background 0.2s;
        background: #fafafa;
    }

    .file-upload:hover {
        border-color: #0f4c4c;
        background: #f5f5f5;
    }

    .file-upload-icon {
        font-size: 26px;
        display: block;
        margin-bottom: 6px;
        color: #6b7280;
    }

    .file-upload-text {
        font-size: 13px;
        color: #6b7280;
    }

    .file-upload input[type="file"] {
        display: none;
    }

    .file-name {
        font-size: 12px;
        color: #0f4c4c;
        margin-top: 8px;
        display: none;
        text-align: center;
    }

    .file-name.show {
        display: block;
    }

    /* Optional text */
    .optional-text {
        font-size: 11px;
        color: #9ca3af;
        font-weight: 400;
        letter-spacing: 0.02em;
    }

    .form-input {
        width: 100%;
        padding: 12px;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        font-size: 14px;
        box-sizing: border-box;
        background: #f3f4f6;
        color: #1f2937;
    }

    .form-input::placeholder {
        color: #9ca3af;
    }

    .form-input:focus {
        outline: none;
        border-color: #0f4c4c;
        box-shadow: 0 0 0 3px rgba(15, 76, 76, 0.12);
    }

    /* Submit button */
    .btn-submit {
        width: 100%;
        padding: 14px 0;
        background: #0f4c4c;
        color: #fff;
        border: none;
        border-radius: 6px;
        font-weight: 700;
        font-size: 14px;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 4px;
    }

    .btn-submit:hover {
        background: #0c3d3d;
    }

    /* Info box */
    .info-box {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        background: #f9fafb;
        border-radius: 8px;
        padding: 14px 16px;
        margin-top: 16px;
    }

    .info-box-icon {
        flex-shrink: 0;
        width: 28px;
        height: 28px;
        border-radius: 6px;
        background: #eef2f2;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }

    .info-box-text {
        font-size: 13px;
        color: #6b7280;
        line-height: 1.5;
    }

    .info-box-text strong {
        display: block;
        color: #111827;
        font-weight: 700;
        font-size: 13px;
        margin-bottom: 2px;
    }

    /* Error/Success messages */
    .error-message {
        color: #dc2626;
        font-size: 13px;
        text-align: center;
        margin-bottom: 16px;
        padding: 10px;
        background: #fef2f2;
        border-radius: 8px;
    }

    .success-message {
        color: #0f4c4c;
        font-size: 13px;
        text-align: center;
        margin-bottom: 16px;
        padding: 10px;
        background: #f0fdf4;
        border-radius: 8px;
    }
</style>

<div class="container">
    <div class="header-title">DormMarket</div>

    <div class="step-indicator">
        <div class="step-badge active">Step 1: Verify your Student</div>
        <div class="step-badge inactive">Step 2: Verify you've rented</div>
    </div>

    <h1 class="main-title">Confirm your Student Status</h1>
    <p class="main-subtitle">
        Upload a document showing you're currently enrolled. This confirms you're a real student -
        separate from confirming you've actually rented a dorm - and unlocks a "Verified Student" badge on your profile.
    </p>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error-message">@Model.ErrorMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="success-message">@Model.SuccessMessage</div>
    }

    <form method="post" enctype="multipart/form-data">
        <div class="form-group">
            <label class="form-label">SCHOOL / UNIVERSITY</label>
            <input type="text" class="form-input" placeholder="Type your school name (e.g., Cebu Institute of Technology - University)" asp-for="School" required />
        </div>

        <div class="form-group">
            <label class="form-label">STUDENT ID</label>
            <div class="file-upload" onclick="document.getElementById('fileInput').click()">
                <span class="file-upload-icon">&#8593;</span>
                <div class="file-upload-text">Upload file (JPG, PNG, max 10MB)</div>
                <input type="file" id="fileInput" name="StudentIdFile" accept=".jpg,.jpeg,.png,.pdf" onchange="updateFileName(this)" required />
            </div>
            <div class="file-name" id="fileDisplayName"></div>
        </div>

        <div class="form-group">
            <label class="form-label">SCHOOL EMAIL <span class="optional-text">(OPTIONAL, SPEEDS REVIEW)</span></label>
            <input type="email" class="form-input" placeholder="yourname@school.edu.ph" asp-for="SchoolEmail" />
        </div>

        <button type="submit" asp-page-handler="Submit" class="btn-submit">Submit for Student Verification</button>
    </form>

    <div class="info-box">
        <div class="info-box-icon">&#128196;</div>
        <div class="info-box-text">
            @if (Model.IsPendingReview)
            {
                <strong>Pending Review</strong>
                <span>Your ID was submitted and is being reviewed. This usually takes 1&ndash;2 days.</span>
            }
            else
            {
                <strong>Pending Review</strong>
                <span>Reviewed within 1&ndash;2 days. This step is optional but recommended &mdash; verified students are more trusted by owners and other students.</span>
            }
        </div>
    </div>
</div>

<script>
    function updateFileName(input) {
        const fileDisplayName = document.getElementById('fileDisplayName');
        if (input.files.length > 0) {
            fileDisplayName.textContent = '📎 ' + input.files[0].name;
            fileDisplayName.classList.add('show');
        } else {
            fileDisplayName.classList.remove('show');
        }
    }
</script>